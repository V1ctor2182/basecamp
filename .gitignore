# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# App data (contains tokens)
# NOTE: not ignoring `data/` wholesale because data/career/ has committed
# config/knowledge files (see career-system exceptions below). Ignore only
# the json files that exist at data/ root (pings/stats/cache/config/repos).
data/*.json
data/*.jsonl
start.sh
.gstack/

# ─────────────────────────────────────────────────────────────
# Career System (data/career/) — explicit ignore of sensitive files
# Managed by feature 01-foundation/02-career-data-layout. Default: files
# are tracked UNLESS listed below. The .gitignore rules above (data/*.json)
# no longer ignore the data/ directory itself, so data/career/** is visible.
# ─────────────────────────────────────────────────────────────

# Sensitive personal / OAuth / state data (MUST NOT commit)
data/career/identity.yml
data/career/.oauth.json
data/career/cv.gdoc-id.local

# Ephemeral runtime state / logs (regenerated per run)
data/career/applications.json
data/career/pipeline.json
data/career/scan-history.jsonl
data/career/archive.jsonl
data/career/scan-cadence-state.json
data/career/scan-cadence-state.json.smoke-backup.*
data/career/llm-costs.jsonl
data/career/followup-templates.md

# QA Bank: legal answers (EEO/visa) + history (application trail) are private
data/career/qa-bank/legal.yml
data/career/qa-bank/history.jsonl

# Resumes: actual base.md content is private; versions/ are auto snapshots
data/career/resumes/*/base.md
data/career/resumes/*/base.gdoc-id
data/career/resumes/*/versions/

# Generated / transient outputs
data/career/reports/*
data/career/output/*
data/career/drafts/*
data/career/feedback/*
data/career/apply-sessions/*
data/career/.playwright/

# Keep .gitkeep files in otherwise-ignored dirs so git retains the dir
# (.playwright/ is runtime-created so no .gitkeep needed there)
!data/career/reports/.gitkeep
!data/career/output/.gitkeep
!data/career/drafts/.gitkeep
!data/career/feedback/.gitkeep
!data/career/apply-sessions/.gitkeep

# Keep README.md in otherwise-ignored dirs (documentation is not data)
!data/career/reports/README.md
!data/career/output/README.md
!data/career/drafts/README.md
!data/career/feedback/README.md
!data/career/apply-sessions/README.md

# Plugin-managed skill / agent installs (feature-room-plugin etc.)
.agents/
.claude/skills/
.claude/agents/
skills/
skills-lock.json
# (.claude/settings.json and .claude/commands/ ARE tracked)

# Embedded repos / local workspaces
career-ops/
