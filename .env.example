# Copy this file to `.env` and fill in real values.
# server.mjs loads `.env` automatically on startup (process.loadEnvFile).
# `.env` is gitignored — never commit real keys.

# LLM backend for Stage A/B evaluation, Mode 1 drafts, CV tailor.
# Option 1 (no API key): run AI calls through the local `claude` CLI,
# using your Claude Code subscription.
CAREER_LLM_BACKEND=cli

# Option 2: use the Anthropic API directly. Remove the line above and
# set a real key from https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: raises GitHub API rate limits for the Tracker app.
# GITHUB_TOKEN=ghp_...
